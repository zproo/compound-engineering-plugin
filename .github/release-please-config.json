{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-component-in-tag": true,
  "release-search-depth": 20,
  "commit-search-depth": 50,
  "plugins": [],
  "packages": {
    ".": {
      "release-type": "simple",
      "package-name": "compound-engineering",
      "changelog-sections": [
        {
          "type": "feat",
          "section": "Features",
          "hidden": false
        },
        {
          "type": "fix",
          "section": "Bug Fixes",
          "hidden": false
        },
        {
          "type": "deps",
          "section": "Dependencies",
          "hidden": false
        },
        {
          "type": "refactor",
          "section": "Refactoring",
          "hidden": false
        }
      ],
      "skip-changelog": true,
      "exclude-paths": [
        "SECURITY.md",
        "PRIVACY.md",
        "favicon.png",
        "docs/",
        "scripts/",
        ".github/",
        ".claude/",
        ".codex/",
        ".gemini/",
        ".cursor/",
        ".windsurf/",
        ".agents/plugins/marketplace.json",
        ".claude-plugin/marketplace.json",
        ".cursor-plugin/marketplace.json"
      ],
      "extra-files": [
        {
          "type": "json",
          "path": "package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": ".cursor-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": ".codex-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": ".agy/plugin.json",
          "jsonpath": "$.version"
        }
      ]
    },
    ".claude-plugin": {
      "release-type": "simple",
      "package-name": "marketplace",
      "release-as": "1.0.3",
      "extra-files": [
        {
          "type": "json",
          "path": "marketplace.json",
          "jsonpath": "$.metadata.version"
        }
      ]
    },
    ".cursor-plugin": {
      "release-type": "simple",
      "package-name": "cursor-marketplace",
      "release-as": "1.0.2",
      "extra-files": [
        {
          "type": "json",
          "path": "marketplace.json",
          "jsonpath": "$.metadata.version"
        }
      ]
    }
  }
}
